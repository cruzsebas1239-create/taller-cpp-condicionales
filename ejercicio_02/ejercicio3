#include <iostream>
using namespace std;


const int LEER = 0b001;       // 1
const int ESCRIBIR = 0b010;   // 2
const int EJECUTAR = 0b100;   // 4

int main() {
    int permisosUsuario;

    cout << "Ingrese el valor entero de permisos (0-7): ";
    cin >> permisosUsuario;

    cout << "\nPermisos detectados:\n";

    if (permisosUsuario & LEER)
        cout << "Tiene permiso de LEER\n";
    else
        cout << "No tiene permiso de LEER\n";

    if (permisosUsuario & ESCRIBIR)
        cout << "Tiene permiso de ESCRIBIR\n";
    else
        cout << "No tiene permiso de ESCRIBIR\n";

    if (permisosUsuario & EJECUTAR)
        cout << "Tiene permiso de EJECUTAR\n";
    else
        cout << "No tiene permiso de EJECUTAR\n";

  
    int agregarEjecucion = permisosUsuario | EJECUTAR;
    cout << "\nSi se agrega EJECUTAR con | el nuevo valor seria: "
         << agregarEjecucion << endl;

    
    int quitarEscritura = permisosUsuario & ~ESCRIBIR;
    cout << "Si se quita ESCRIBIR con & ~ el nuevo valor seria: "
         << quitarEscritura << endl;

    return 0;
}
